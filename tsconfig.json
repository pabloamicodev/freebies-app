{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false,
    "paths": {
      "@promo/shared-types": ["./packages/shared-types/src/index.ts"],
      "@promo/shared-types/*": ["./packages/shared-types/src/*"],
      "@promo/rule-engine": ["./packages/rule-engine/src/index.ts"],
      "@promo/rule-engine/*": ["./packages/rule-engine/src/*"],
      "@promo/db": ["./packages/db/src/index.ts"],
      "@promo/db/*": ["./packages/db/src/*"],
      "drizzle-orm": ["./apps/shopify-admin/node_modules/drizzle-orm"],
      "drizzle-orm/*": ["./apps/shopify-admin/node_modules/drizzle-orm/*"],
      "postgres": ["./apps/shopify-admin/node_modules/postgres"]
    }
  },
  "exclude": ["node_modules", "dist", "build", "target"]
}
