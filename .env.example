# ── Shopify App credentials (from Partners Dashboard) ──
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here
SHOPIFY_APP_URL=https://your-tunnel-url.ngrok.io
# MUST match [access_scopes].scopes in apps/shopify-admin/shopify.app.toml exactly,
# or the app re-prompts for auth / hits missing-scope 403s.
SCOPES=read_products,read_product_listings,read_inventory,read_publications,read_markets,read_discounts,write_discounts,read_customers,read_orders,read_metafields,write_metafields,read_metaobjects,write_metaobjects,read_locales,read_themes,write_app_proxy

# ── Database ──
DATABASE_URL=postgresql://postgres:password@localhost:5432/promo_engine
# Neon only: unpooled connection URL for Drizzle migrations (bypasses PgBouncer).
# Find it in Neon dashboard → Connection Details → "Connection pooling" toggle OFF.
# Falls back to DATABASE_URL for local dev (no pooler).
DATABASE_URL_UNPOOLED=

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── Cron authentication ──
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=your_cron_secret_here

# ── App ──
NODE_ENV=development
PORT=3000

# ── Encryption key for access tokens (AES-256-GCM, 32 bytes hex) ──
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=your_32_byte_hex_key_here

# ── Sentry (optional) ──
SENTRY_DSN=

# ── Analytics retention ──
# Days to retain analytics events before cleanup cron deletes them. Default: 90.
ANALYTICS_RETENTION_DAYS=90

# ── Feature flags ──
ENABLE_DEBUG_MODE=false
ENABLE_STOREFRONT_RUNTIME=true
ENABLE_WASM_EVALUATOR=false
