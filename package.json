{
  "name": "promo-engine",
  "private": true,
  "version": "0.1.0",
  "description": "Internal Shopify promotion engine — BOGOS functional parity",
  "scripts": {
    "dev": "pnpm --filter shopify-admin dev",
    "build": "pnpm -r build",
    "build:storefront": "node scripts/build-storefront.mjs",
    "build:admin": "pnpm --filter shopify-admin build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:rust": "bash scripts/benchmark-functions.sh",
    "test:e2e": "pnpm --filter shopify-admin test:e2e",
    "test:load": "npx tsx apps/shopify-admin/tests/load/evaluation.load.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "setup:rust": "bash scripts/setup-rust.sh",
    "check:bundles": "node scripts/check-bundle-sizes.mjs",
    "ci": "pnpm typecheck && pnpm test && pnpm check:bundles",
    "deploy:migrate": "pnpm db:migrate",
    "db:generate": "pnpm --filter @promo/db db:generate",
    "db:migrate": "pnpm --filter @promo/db db:migrate",
    "db:studio": "pnpm --filter @promo/db db:studio"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^9.15.0",
    "jiti": "^2.4.2",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "ioredis": "5.6.1",
      "bullmq": "5.78.1",
      "esbuild": "0.28.1",
      "@vercel/static-config>ajv": "8.20.0",
      "@shopify/shopify-api": "^13.0.0"
    }
  }
}
