{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@promo/db": ["../../packages/db/src/index.ts"],
      "@promo/db/*": ["../../packages/db/src/*"],
      "@promo/shared-types": ["../../packages/shared-types/src/index.ts"],
      "@promo/shared-types/*": ["../../packages/shared-types/src/*"],
      "drizzle-orm": ["../../packages/db/node_modules/drizzle-orm/index.d.ts"],
      "drizzle-orm/*": ["../../packages/db/node_modules/drizzle-orm/*"]
    }
  },
  "include": ["src"]
}
