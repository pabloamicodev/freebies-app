# E2E test environment — copy to .env.test and fill in your values
# These are also needed as GitHub Actions secrets under the "e2e" environment.
#
# DEV_STORE_URL
#   URL of a Shopify development store with the app installed and at least
#   one active gift offer configured (e.g. "spend $50 -> free gift").
#   Example: https://my-dev-store.myshopify.com
DEV_STORE_URL=https://YOUR-DEV-STORE.myshopify.com

# DEV_STORE_STOREFRONT_TOKEN
#   A Storefront API access token from the dev store.
#   Generate one in Shopify Admin -> Settings -> Apps and sales channels ->
#   "Develop apps" -> your app -> "API credentials" -> Storefront API access scopes.
#   Required scopes: unauthenticated_read_product_listings,
#                    unauthenticated_write_checkouts,
#                    unauthenticated_read_selling_plans
DEV_STORE_STOREFRONT_TOKEN=your-storefront-api-token-here

# --- GitHub Actions Setup ---
# Go to: github.com/YOUR_ORG/freebies-app -> Settings -> Environments -> e2e
# Add the two secrets above (DEV_STORE_URL and DEV_STORE_STOREFRONT_TOKEN).
# The CI workflow already reads them via ${{ secrets.DEV_STORE_URL }}
