{
  "framework": "react-router",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && cd apps/shopify-admin && pnpm exec react-router build",
  "outputDirectory": "build/client",
  "alias": ["freebies-app-shopify-admin.vercel.app"],
  "crons": [
    { "path": "/api/cron/offers", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/analytics-cleanup", "schedule": "0 3 * * *" }
  ]
}
